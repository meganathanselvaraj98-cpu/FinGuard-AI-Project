APP_NAME=FinGuard AI
APP_ENV=development
ACCESS_TOKEN_MINUTES=30
MAX_UPLOAD_MB=50
COOKIE_SECURE=false

# Leave both blank for local SQLite mode.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Keep the same values across local and deployed environments.
SECRET_KEY=
HASH_PEPPER=
FIELD_ENCRYPTION_KEY=

# Recommended for cloud deployment.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Optional local SQLite override.
DATABASE_URL=
